# ─────────────────────────────────────────────────────────────────────────────
# KAIDEEDER.com — Environment Variables (Example / Template)
# Copy this file to .env (local) or .env.production (server)
# and fill in the real values.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Node Environment ────────────────────────────────────────────────────────
NODE_ENV="production"

# ─── Database (MySQL) ────────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Hostinger hPanel → Databases → MySQL Databases
DATABASE_URL="mysql://kaideeder_user:YOUR_DB_PASSWORD@localhost:3306/kaideeder_db"

# ─── Application URL ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://kaideeder.com"

# ─── JWT Secret (Tenant Users) ───────────────────────────────────────────────
# MUST be at least 32 random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(40).toString('hex'))"
JWT_SECRET="REPLACE_WITH_RANDOM_32_CHAR_SECRET"

# ─── Admin JWT Secret ────────────────────────────────────────────────────────
# Same rule: 32+ random characters, different from JWT_SECRET
ADMIN_JWT_SECRET="REPLACE_WITH_ANOTHER_RANDOM_SECRET"
