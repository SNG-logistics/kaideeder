generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// TENANT (Multi-tenant root)
// ─────────────────────────────────────────────

model Tenant {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  displayName String?      // ชื่อร้านที่แสดงใน UI (ถ้าไม่ตั้ง จะใช้ name)
  storeNameLao String?     // ชื่อร้านภาษาลาว
  logoUrl     String?      // URL รูปโลโก้ (relative path เช่น /uploads/logos/store-001.png)
  status      TenantStatus @default(ACTIVE)
  subEndsAt   DateTime?
  graceEndsAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // ── Store settings ──────────────────────────────
  currency      String   @default("LAK")  // "LAK" | "THB"
  language      String   @default("th")   // "th" | "lo" | "both"
  phone         String?                   // เบอร์โทรร้าน
  address       String?  @db.Text         // ที่อยู่ร้าน
  taxId         String?                   // เลขประจำตัวผู้เสียภาษี / ທຸລະກິດ
  receiptHeader String?  @db.Text         // หัวใบบิล (custom text / HTML)
  timezone      String   @default("Asia/Vientiane")

  // Store data relations
  users            User[]
  categories       Category[]
  products         Product[]
  locations        Location[]
  inventory        Inventory[]
  stockMovements   StockMovement[]
  purchaseOrders   PurchaseOrder[]
  purchaseItems    PurchaseItem[]
  suppliers        Supplier[]
  stockTransfers   StockTransfer[]
  transferItems    TransferItem[]
  stockAdjustments StockAdjustment[]
  adjustmentItems  AdjustmentItem[]
  recipes          Recipe[]
  recipeBOMs       RecipeBOM[]
  salesImports     SalesImport[]
  salesImportItems SalesImportItem[]
  orders           Order[]
  orderItems       OrderItem[]
  payments         Payment[]
  salesEvents      SalesEvent[]
  tables           DiningTable[]
  productAliases   ProductAlias[]
  skuSuggestions   SkuSuggestion[]

  // SaaS relations
  wallet           Wallet?
  walletLedger     WalletLedger[]
  subs             Subscription[]
  topups           TopupRequest[]
  auditLogs        AuditLog[]

  @@map("tenants")
}

// ─────────────────────────────────────────────
// SYSTEM ADMINS (SuperAdmin / Admin1-3)
// ─────────────────────────────────────────────

model AdminUser {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String
  role         AdminRole
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  auditLogs         AuditLog[]
  walletLedgerEntry WalletLedger[]
  topupReviews      TopupRequest[]

  @@map("admin_users")
}

// ─────────────────────────────────────────────
// STORE USERS (scoped to tenant)
// ─────────────────────────────────────────────

model User {
  id                String            @id @default(cuid())
  tenantId          String
  username          String
  passwordHash      String
  name              String
  role              Role              @default(VIEWER)
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  itemStatusChanges OrderItem[]       @relation("ItemStatusChangedBy")
  orders            Order[]
  purchaseOrders    PurchaseOrder[]
  adjustments       StockAdjustment[]
  stockMovements    StockMovement[]
  transfers         StockTransfer[]
  topupRequests     TopupRequest[]
  auditLogs         AuditLog[]

  @@unique([tenantId, username])
  @@index([tenantId])
  @@map("users")
}

// ─────────────────────────────────────────────
// MASTER DATA
// ─────────────────────────────────────────────

model Category {
  id       String    @id @default(cuid())
  tenantId String
  code     String
  name     String
  nameEn   String?
  color    String?
  icon     String?
  isActive Boolean   @default(true)

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("categories")
}

model Product {
  id             String          @id @default(cuid())
  tenantId       String
  sku            String
  name           String
  nameTh         String?
  nameLao        String?
  categoryId     String
  productType    ProductType     @default(SALE_ITEM)
  unit           String
  unitAlt        String?
  convFactor     Float?
  costPrice      Float           @default(0)
  salePrice      Float           @default(0)
  reorderPoint   Float           @default(0)
  minQty         Float           @default(0)
  isActive       Boolean         @default(true)
  note           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  imageUrl       String?
  imageBase64    String?         @db.Text

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  category       Category        @relation(fields: [categoryId], references: [id])
  inventory      Inventory[]
  orderItems     OrderItem[]
  purchaseItems  PurchaseItem[]
  recipes        RecipeBOM[]     @relation("RecipeProduct")
  bom            RecipeBOM[]
  stockMovements StockMovement[]
  aliases        ProductAlias[]
  suggestions    SkuSuggestion[] @relation("MatchedProduct")

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([categoryId], map: "products_categoryId_fkey")
  @@map("products")
}

model Location {
  id            String          @id @default(cuid())
  tenantId      String
  code          String
  name          String
  nameLao       String?
  type          LocationType
  sortOrder     Int             @default(0)
  isActive      Boolean         @default(true)

  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  inventory     Inventory[]
  fromMovements StockMovement[] @relation("FromLocation")
  toMovements   StockMovement[] @relation("ToLocation")
  transferFrom  StockTransfer[] @relation("TransferFrom")
  transferTo    StockTransfer[] @relation("TransferTo")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("locations")
}

// ─────────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────────

model Inventory {
  id          String   @id @default(cuid())
  tenantId    String
  productId   String
  locationId  String
  quantity    Float    @default(0)
  reservedQty Float    @default(0)
  avgCost     Float    @default(0)
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  location    Location @relation(fields: [locationId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])

  @@unique([tenantId, productId, locationId])
  @@index([tenantId])
  @@index([locationId], map: "inventory_locationId_fkey")
  @@map("inventory")
}

model StockMovement {
  id             String       @id @default(cuid())
  tenantId       String
  productId      String
  fromLocationId String?
  toLocationId   String?
  quantity       Float
  unitCost       Float        @default(0)
  totalCost      Float        @default(0)
  type           MovementType
  referenceId    String?
  referenceType  String?
  note           String?
  createdById    String?
  createdAt      DateTime     @default(now())

  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  createdBy      User?        @relation(fields: [createdById], references: [id])
  fromLocation   Location?    @relation("FromLocation", fields: [fromLocationId], references: [id])
  product        Product      @relation(fields: [productId], references: [id])
  toLocation     Location?    @relation("ToLocation", fields: [toLocationId], references: [id])

  @@index([tenantId])
  @@index([productId])
  @@index([createdAt])
  @@index([type])
  @@index([createdById], map: "stock_movements_createdById_fkey")
  @@index([fromLocationId], map: "stock_movements_fromLocationId_fkey")
  @@index([toLocationId], map: "stock_movements_toLocationId_fkey")
  @@map("stock_movements")
}

// ─────────────────────────────────────────────
// PURCHASING
// ─────────────────────────────────────────────

model PurchaseOrder {
  id           String         @id @default(cuid())
  tenantId     String
  poNumber     String
  supplierId   String?
  status       POStatus       @default(DRAFT)
  totalAmount  Float          @default(0)
  note         String?
  billImageUrl String?
  purchaseDate DateTime       @default(now())
  createdById  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  items        PurchaseItem[]
  createdBy    User?          @relation(fields: [createdById], references: [id])
  supplier     Supplier?      @relation(fields: [supplierId], references: [id])

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@index([createdById], map: "purchase_orders_createdById_fkey")
  @@index([supplierId], map: "purchase_orders_supplierId_fkey")
  @@map("purchase_orders")
}

model PurchaseItem {
  id              String        @id @default(cuid())
  tenantId        String
  purchaseOrderId String
  productId       String
  locationId      String
  quantity        Float
  unitCost        Float
  totalCost       Float

  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@index([tenantId])
  @@index([productId], map: "purchase_items_productId_fkey")
  @@index([purchaseOrderId], map: "purchase_items_purchaseOrderId_fkey")
  @@map("purchase_items")
}

model Supplier {
  id       String          @id @default(cuid())
  tenantId String
  name     String
  phone    String?
  note     String?
  isActive Boolean         @default(true)

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  orders   PurchaseOrder[]

  @@index([tenantId])
  @@map("suppliers")
}

// ─────────────────────────────────────────────
// TRANSFERS & ADJUSTMENTS
// ─────────────────────────────────────────────

model StockTransfer {
  id             String         @id @default(cuid())
  tenantId       String
  fromLocationId String
  toLocationId   String
  status         TransferStatus @default(PENDING)
  note           String?
  requestedById  String?
  transferDate   DateTime       @default(now())
  createdAt      DateTime       @default(now())

  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  fromLocation   Location       @relation("TransferFrom", fields: [fromLocationId], references: [id])
  requestedBy    User?          @relation(fields: [requestedById], references: [id])
  toLocation     Location       @relation("TransferTo", fields: [toLocationId], references: [id])
  items          TransferItem[]

  @@index([tenantId])
  @@index([fromLocationId], map: "stock_transfers_fromLocationId_fkey")
  @@index([requestedById], map: "stock_transfers_requestedById_fkey")
  @@index([toLocationId], map: "stock_transfers_toLocationId_fkey")
  @@map("stock_transfers")
}

model TransferItem {
  id         String        @id @default(cuid())
  tenantId   String
  transferId String
  productId  String
  quantity   Float

  tenant     Tenant        @relation(fields: [tenantId], references: [id])
  transfer   StockTransfer @relation(fields: [transferId], references: [id])

  @@index([tenantId])
  @@index([transferId], map: "transfer_items_transferId_fkey")
  @@map("transfer_items")
}

model StockAdjustment {
  id           String           @id @default(cuid())
  tenantId     String
  locationId   String
  status       AdjustmentStatus @default(PENDING)
  reason       String
  note         String?
  adjustedById String?
  adjustedAt   DateTime         @default(now())
  createdAt    DateTime         @default(now())

  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  items        AdjustmentItem[]
  adjustedBy   User?            @relation(fields: [adjustedById], references: [id])

  @@index([tenantId])
  @@index([adjustedById], map: "stock_adjustments_adjustedById_fkey")
  @@map("stock_adjustments")
}

model AdjustmentItem {
  id           String          @id @default(cuid())
  tenantId     String
  adjustmentId String
  productId    String
  locationId   String
  systemQty    Float
  actualQty    Float
  diffQty      Float
  unitCost     Float           @default(0)

  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  adjustment   StockAdjustment @relation(fields: [adjustmentId], references: [id])

  @@index([tenantId])
  @@index([adjustmentId], map: "adjustment_items_adjustmentId_fkey")
  @@map("adjustment_items")
}

// ─────────────────────────────────────────────
// RECIPES
// ─────────────────────────────────────────────

model Recipe {
  id          String      @id @default(cuid())
  tenantId    String
  menuName    String
  posMenuCode String?
  isActive    Boolean     @default(true)
  note        String?

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  bom         RecipeBOM[]

  @@index([tenantId])
  @@map("recipes")
}

model RecipeBOM {
  id         String   @id @default(cuid())
  tenantId   String
  recipeId   String
  productId  String
  menuId     String?
  locationId String
  quantity   Float
  unit       String

  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  menu       Product? @relation("RecipeProduct", fields: [menuId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])
  recipe     Recipe   @relation(fields: [recipeId], references: [id])

  @@index([tenantId])
  @@index([menuId], map: "recipe_bom_menuId_fkey")
  @@index([productId], map: "recipe_bom_productId_fkey")
  @@index([recipeId], map: "recipe_bom_recipeId_fkey")
  @@map("recipe_bom")
}

// ─────────────────────────────────────────────
// SKU MASTER — ALIASES & SUGGESTION QUEUE
// ─────────────────────────────────────────────

/// ชื่อเรียกอื่นของ product (ใช้สำหรับ auto-map ตอน import)
model ProductAlias {
  id        String   @id @default(cuid())
  tenantId  String
  productId String
  alias     String   // ชื่อเรียกอื่น / คำในบิล
  source    String?  // "manual" | "import" | "bill"
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([tenantId, alias])
  @@index([tenantId])
  @@index([productId], map: "product_aliases_productId_fkey")
  @@map("product_aliases")
}

/// คิวอนุมัติ SKU ใหม่ / mapping — สร้างเมื่อ import แล้ว score < 0.85
model SkuSuggestion {
  id               String              @id @default(cuid())
  tenantId         String
  importSource     String?             // ชื่อไฟล์ที่มาจาก import
  rawName          String              // ชื่อดิบจาก import/bill
  rawUnit          String?
  rawCategory      String?
  rawCostPrice     Float?
  rawSalePrice     Float?
  suggestedSku     String?             // SKU ที่ระบบเสนอ (ยังไม่สร้างจริง)
  matchedProductId String?             // productId ที่ match ได้ (score 0.60–0.84)
  matchScore       Float?              // คะแนน similarity
  status           SkuSuggestionStatus @default(PENDING)
  resolvedById     String?             // userId ที่ approve/reject
  resolvedAt       DateTime?
  note             String?
  createdAt        DateTime            @default(now())

  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  matchedProduct Product? @relation("MatchedProduct", fields: [matchedProductId], references: [id])

  @@index([tenantId, status])
  @@index([matchedProductId], map: "sku_suggestions_matchedProductId_fkey")
  @@map("sku_suggestions")
}

// ─────────────────────────────────────────────
// SALES IMPORT
// ─────────────────────────────────────────────

model SalesImport {
  id           String            @id @default(cuid())
  tenantId     String
  fileName     String
  importDate   DateTime
  saleDate     DateTime
  status       SalesImportStatus @default(PENDING)
  totalAmount  Float             @default(0)
  totalItems   Int               @default(0)
  note         String?
  importedById String?
  importedAt   DateTime          @default(now())

  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  items        SalesImportItem[]

  @@index([tenantId])
  @@map("sales_imports")
}

model SalesImportItem {
  id            String      @id @default(cuid())
  tenantId      String
  importId      String
  rowNumber     Int
  menuName      String
  unitPrice     Float
  quantity      Float
  totalAmount   Float
  category      String?
  stockDeducted Boolean     @default(false)
  matchedRecipe String?

  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  import        SalesImport @relation(fields: [importId], references: [id])

  @@index([tenantId])
  @@index([importId], map: "sales_import_items_importId_fkey")
  @@map("sales_import_items")
}

// ─────────────────────────────────────────────
// DINING / POS
// ─────────────────────────────────────────────

model DiningTable {
  id       String      @id @default(cuid())
  tenantId String
  number   Int
  name     String
  zone     String
  seats    Int         @default(4)
  status   TableStatus @default(AVAILABLE)
  isActive Boolean     @default(true)

  tenant   Tenant      @relation(fields: [tenantId], references: [id])
  orders   Order[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@map("dining_tables")
}

model Order {
  id            String       @id @default(cuid())
  tenantId      String
  orderNumber   String
  tableId       String?
  status        OrderStatus  @default(OPEN)
  subtotal      Float        @default(0)
  discount      Float        @default(0)
  discountType  DiscountType @default(AMOUNT)
  serviceCharge Float        @default(0)
  vat           Float        @default(0)
  totalAmount   Float        @default(0)
  note          String?
  createdById   String?
  openedAt      DateTime     @default(now())
  closedAt      DateTime?

  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  items         OrderItem[]
  createdBy     User?        @relation(fields: [createdById], references: [id])
  table         DiningTable? @relation(fields: [tableId], references: [id])
  payments      Payment[]
  salesEvents   SalesEvent[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([status])
  @@index([openedAt])
  @@index([createdById], map: "orders_createdById_fkey")
  @@index([tableId], map: "orders_tableId_fkey")
  @@map("orders")
}

model OrderItem {
  id                String        @id @default(cuid())
  tenantId          String
  orderId           String
  productId         String
  quantity          Float         @default(1)
  unitPrice         Float         @default(0)
  note              String?
  isCancelled       Boolean       @default(false)
  cancelReason      String?
  kitchenStatus     KitchenStatus @default(PENDING)
  stationId         String?
  statusChangedAt   DateTime?
  statusChangedById String?

  tenant            Tenant        @relation(fields: [tenantId], references: [id])
  order             Order         @relation(fields: [orderId], references: [id])
  product           Product       @relation(fields: [productId], references: [id])
  statusChangedBy   User?         @relation("ItemStatusChangedBy", fields: [statusChangedById], references: [id])

  @@index([tenantId])
  @@index([orderId], map: "order_items_orderId_fkey")
  @@index([productId], map: "order_items_productId_fkey")
  @@index([statusChangedById], map: "order_items_statusChangedById_fkey")
  @@map("order_items")
}

model SalesEvent {
  id         String   @id @default(cuid())
  tenantId   String
  orderId    String
  occurredAt DateTime @default(now())
  payload    Json
  processed  Boolean  @default(false)

  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id])

  @@index([tenantId])
  @@index([occurredAt])
  @@index([processed])
  @@index([orderId], map: "sales_events_orderId_fkey")
  @@map("sales_events")
}

model Payment {
  id             String        @id @default(cuid())
  tenantId       String
  orderId        String
  method         PaymentMethod @default(CASH)
  amount         Float         @default(0)
  receivedAmount Float         @default(0)
  changeAmount   Float         @default(0)
  reference      String?
  paidAt         DateTime      @default(now())

  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  order          Order         @relation(fields: [orderId], references: [id])

  @@index([tenantId])
  @@index([orderId], map: "payments_orderId_fkey")
  @@map("payments")
}

// ─────────────────────────────────────────────
// SAAS – PLANS & SUBSCRIPTIONS
// ─────────────────────────────────────────────

model Plan {
  id           String         @id @default(cuid())
  code         String         @unique // e.g. PLAN_1M, PLAN_3M
  name         String
  priceLAK     Int
  durationDays Int
  features     Json?
  isActive     Boolean        @default(true)

  subs         Subscription[]

  @@map("plans")
}

model Subscription {
  id        String    @id @default(cuid())
  tenantId  String
  planId    String
  startAt   DateTime
  endAt     DateTime
  status    SubStatus @default(ACTIVE)
  autoRenew Boolean   @default(false)

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  plan      Plan      @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@index([endAt])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────
// SAAS – WALLET & LEDGER (immutable ledger)
// ─────────────────────────────────────────────

model Wallet {
  id         String         @id @default(cuid())
  tenantId   String         @unique
  balanceLAK Int            @default(0)
  updatedAt  DateTime       @updatedAt

  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  ledger     WalletLedger[]

  @@map("wallets")
}

/// Immutable — never UPDATE or DELETE rows. Source of truth for balance.
model WalletLedger {
  id               String     @id @default(cuid())
  walletId         String
  tenantId         String
  type             LedgerType
  amountLAK        Int        // positive = credit (topup/refund), negative = debit (billing)
  refType          String?    // "TOPUP" | "SUBSCRIPTION" | "ADJUST"
  refId            String?
  note             String?
  createdAt        DateTime   @default(now())
  createdByAdminId String?

  wallet           Wallet     @relation(fields: [walletId], references: [id])
  tenant           Tenant     @relation(fields: [tenantId], references: [id])
  createdByAdmin   AdminUser? @relation(fields: [createdByAdminId], references: [id])

  @@index([walletId])
  @@index([tenantId, createdAt])
  @@index([type])
  @@map("wallet_ledger")
}

// ─────────────────────────────────────────────
// SAAS – TOPUP REQUESTS
// ─────────────────────────────────────────────

model TopupRequest {
  id                String      @id @default(cuid())
  tenantId          String
  userId            String
  amountLAK         Int
  channel           String      // BCEL / transfer / cash / …
  proofUrl          String?
  status            TopupStatus @default(PENDING)
  createdAt         DateTime    @default(now())
  reviewedAt        DateTime?
  reviewedByAdminId String?

  tenant            Tenant      @relation(fields: [tenantId], references: [id])
  user              User        @relation(fields: [userId], references: [id])
  reviewedBy        AdminUser?  @relation(fields: [reviewedByAdminId], references: [id])

  @@index([tenantId, status])
  @@index([userId])
  @@map("topup_requests")
}

// ─────────────────────────────────────────────
// SAAS – AUDIT LOG
// ─────────────────────────────────────────────

/// Every action by AdminUser (or significant store-user action) must produce one row.
model AuditLog {
  id        String    @id @default(cuid())
  actorType ActorType
  adminId   String?   // set when actorType = ADMIN
  userId    String?   // set when actorType = TENANT_USER
  tenantId  String?
  action    String    // e.g. "APPROVE_TOPUP" | "DISABLE_TENANT" | "CHANGE_PLAN"
  payload   Json?
  ip        String?
  createdAt DateTime  @default(now())

  admin     AdminUser? @relation(fields: [adminId], references: [id])
  user      User?      @relation(fields: [userId], references: [id])
  tenant    Tenant?    @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([action])
  @@index([adminId])
  @@map("audit_logs")
}

